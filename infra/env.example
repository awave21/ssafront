APP_NAME=agent-platform
ENVIRONMENT=prod

# Публичные URL
PUBLIC_BASE_URL=https://api.chatmedbot.ru
INVITE_LINK_BASE_URL=https://lk.chatmedbot.ru
API_PREFIX=/api/v1

# База данных
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=agents
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Проброс API-порта на хост
API_BIND_ADDRESS=127.0.0.1
API_BIND_PORT=8000

# Redis и пул БД
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me

# JWT и API-ключи
JWT_SECRET=change-me
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_ALGORITHM=HS256
JWT_AUDIENCE=agent-platform
JWT_ISSUER=agent-platform
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
API_KEY_PEPPER=change-me
ALLOW_TEST_TOKENS=false
AUTH_API_KEYS={"replace-with-real-key":{"tenant_id":"00000000-0000-0000-0000-000000000001","user_id":"00000000-0000-0000-0000-000000000001","scopes":["tools:write"]}}

# Шифрование учётных данных
CREDENTIALS_ENCRYPTION_KEY=

# Rate limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_RUNS=20/minute
RATE_LIMIT_AUTH_LOGIN=5/minute
RATE_LIMIT_AUTH_REFRESH=30/minute
RATE_LIMIT_AUTH_REGISTER=3/hour
AUTH_LOGIN_BRUTEFORCE_ENABLED=true
AUTH_LOGIN_BRUTEFORCE_WINDOW_SECONDS=900
AUTH_LOGIN_BRUTEFORCE_PROGRESSIVE_ENABLED=true
AUTH_LOGIN_BRUTEFORCE_BASE_BLOCK_SECONDS=60
AUTH_LOGIN_BRUTEFORCE_MAX_BLOCK_SECONDS=7200
AUTH_LOGIN_BRUTEFORCE_MAX_ATTEMPTS_PER_IP=40
AUTH_LOGIN_BRUTEFORCE_MAX_ATTEMPTS_PER_EMAIL=10
AUTH_LOGIN_BRUTEFORCE_MAX_ATTEMPTS_PER_IP_EMAIL=5
# Осторожно: /24 может задеть пользователей за NAT. По умолчанию выключено.
AUTH_LOGIN_BRUTEFORCE_SUBNET_ENABLED=false
AUTH_LOGIN_BRUTEFORCE_MAX_ATTEMPTS_PER_SUBNET=120

# LLM и таймауты инструментов
PYDANTICAI_DEFAULT_MODEL=openai:gpt-4o-mini
OPENAI_API_KEY=
TOOL_DEFAULT_TIMEOUT_MS=15000
TOOL_MAX_TIMEOUT_MS=60000
TOOL_RETRY_ATTEMPTS=2
WAPPI_BASE_URL=https://wappi.pro
WAPPI_API_TOKEN=
WAPPI_TIMEOUT_SECONDS=15
WAPPI_RETRY_ATTEMPTS=2
WAPPI_RETRY_MIN_SECONDS=0.5
WAPPI_RETRY_MAX_SECONDS=4.0
WAPPI_PROFILE_TARIFF_ID=1
WAPPI_PROFILE_PROMO_CODE=
SSE_KEEPALIVE_SECONDS=15

# Script flow retrieval index worker resources
SCRIPT_FLOW_INDEX_WORKER_CPUS=0.40
SCRIPT_FLOW_INDEX_WORKER_MEM_LIMIT=512m
SCRIPT_FLOW_INDEX_WORKER_MEM_RESERVATION=256m

# Logfire
LOGFIRE_TOKEN=
LOGFIRE_RECONCILE_ENABLED=true
LOGFIRE_READ_TOKEN=
LOGFIRE_BASE_URL=https://logfire-us.pydantic.dev
LOGFIRE_RECONCILE_INITIAL_DELAY_SECONDS=1.5
LOGFIRE_RECONCILE_MAX_ATTEMPTS=3
LOGFIRE_RECONCILE_RETRY_DELAY_SECONDS=2.0
LOGFIRE_RECONCILE_TIMEOUT_SECONDS=10

# CORS и refresh cookie
CORS_ORIGINS=https://lk.chatmedbot.ru,http://localhost:3000,http://127.0.0.1:3000,https://api.chatmedbot.ru
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
AUTH_REFRESH_COOKIE_SAMESITE=none
AUTH_REFRESH_COOKIE_SECURE=true

# Caddy и домены фронта
ACME_EMAIL=admin@chatmedbot.ru
DOCS_AUTH_USER=docs_admin
DOCS_AUTH_HASH=$$2b$$12$$replace_with_caddy_bcrypt_hash
MONITOR_PATH=/ops-change-me/
MONITOR_AUTH_USER=ops_monitor
MONITOR_AUTH_HASH=$$2b$$12$$replace_with_caddy_bcrypt_hash
SEND_TELEGRAM=NO
TELEGRAM_BOT_TOKEN=
DEFAULT_RECIPIENT_TELEGRAM=
ALERTS_TELEGRAM_BOT_TOKEN=
ALERTS_TELEGRAM_CHAT_ID=
FRONTEND_API_BASE=/api/v1
FRONTEND_SITE_URL=https://lk.chatmedbot.ru
FRONTEND_DOMAIN=lk.chatmedbot.ru

# Лимиты ресурсов контейнеров
API_CPUS=2.0
API_MEM_LIMIT=1024m
API_MEM_RESERVATION=512m
DB_CPUS=0.60
DB_MEM_LIMIT=1280m
DB_MEM_RESERVATION=640m
REDIS_CPUS=0.15
REDIS_MEM_LIMIT=320m
REDIS_MEM_RESERVATION=160m
FRONTEND_CPUS=0.50
FRONTEND_MEM_LIMIT=256m
FRONTEND_MEM_RESERVATION=128m
CADDY_CPUS=0.50
CADDY_MEM_LIMIT=256m
CADDY_MEM_RESERVATION=128m
NETDATA_CPUS=0.35
NETDATA_MEM_LIMIT=384m
NETDATA_MEM_RESERVATION=192m
PGADMIN_CPUS=0.10
PGADMIN_MEM_LIMIT=192m
PGADMIN_MEM_RESERVATION=128m
WATCHER_CPUS=0.05
WATCHER_MEM_LIMIT=96m
WATCHER_MEM_RESERVATION=64m
SCRIPT_FLOW_INDEX_WORKER_CPUS=0.40
SCRIPT_FLOW_INDEX_WORKER_MEM_LIMIT=512m
SCRIPT_FLOW_INDEX_WORKER_MEM_RESERVATION=256m
