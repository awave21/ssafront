{
	"mcpServers": {
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp"
			],
			"env": {
				"DEFAULT_MINIMUM_TOKENS": ""
			}
		},
		"sequentialthinking": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			]
		},
		"postgres": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-postgres",
				"postgresql+asyncpg://postgres:postgres@agentsapp.integration-ai.ru:5432/agents"
			],
			"alwaysAllow": [
				"query"
			]
		},
		"banani": {
			"type": "streamableHttp",
			"url": "https://app.banani.co/api/mcp/mcp",
			"headers": {
				"Authorization": "Bearer bnni_qvEiuT0JQNxyW70xncHmADY1IXYMYMCJ"
			}
		}
	}
}
