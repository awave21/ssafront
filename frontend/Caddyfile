:80 {
	root * /usr/share/caddy
	encode zstd gzip
	try_files {path} /index.html

	@nuxtAssets path /_nuxt/*
	header @nuxtAssets Cache-Control "public, max-age=31536000, immutable"

	@html {
		path *.html
		path /
	}
	header @html Cache-Control "no-cache, must-revalidate"

	# Widget loader — cacheable, any origin can load it
	@widgetLoader path /widget/loader.js
	header @widgetLoader Cache-Control "public, max-age=3600"
	header @widgetLoader Access-Control-Allow-Origin "*"

	file_server
}
